*** Settings ***
Library     RequestsLibrary
Library     Collections
Resource    common.resource
Variables   ../variables/env.yaml


*** Keywords ***
Criar Cliente
    [Documentation]    Cria um cliente no Cadastros. Retorna o clienteId.
    ...                Quando ${cpf} Ă© vazio, gera um CPF vĂˇlido aleatĂłrio.
    ...                O ${email} Ă© desambiguado com timestamp+random pra evitar colisĂŁo entre runs
    ...                (Cadastros enforce email unique).
    [Arguments]    ${nome}=JoĂŁo Silva    ${email}=joao.e2e@mecanica.test    ${cpf}=${EMPTY}
    IF    '${cpf}' == '${EMPTY}'
        ${cpf}=    Gerar CPF Valido
    END
    ${suffix}=     Evaluate    f"{int(__import__('time').time())}{__import__('random').randint(100,999)}"
    ${user}=       Evaluate    "${email}".split("@")[0]
    ${domain}=     Evaluate    "${email}".split("@")[1]
    ${email}=      Set Variable    ${user}+${suffix}@${domain}
    ${body}=    Create Dictionary
    ...    nomeCivil=${nome}
    ...    email=${email}
    ...    identificacaoFiscal=${cpf}
    ...    telefone=11987654321
    ${response}=    POST    ${CADASTROS_URL}/clientes    json=${body}    expected_status=201
    ${id}=    Get From Dictionary    ${response.json()}    id
    Log    Cliente criado: ${id} (CPF=${cpf}, email=${email})
    RETURN    ${id}

Adicionar Veiculo
    [Documentation]    Adiciona um veĂ­culo a um cliente. Retorna o veiculoId.
    [Arguments]    ${cliente_id}    ${modelo}=Onix    ${marca}=Chevrolet    ${placa}=ABC1D23    ${ano}=2022
    ${body}=    Create Dictionary
    ...    modelo=${modelo}
    ...    marca=${marca}
    ...    placa=${placa}
    ...    ano=${ano}
    ${response}=    POST    ${CADASTROS_URL}/clientes/${cliente_id}/veiculos
    ...    json=${body}    expected_status=201
    ${id}=    Get From Dictionary    ${response.json()}    id
    Log    VeĂ­culo criado: ${id}
    RETURN    ${id}

Criar Produto
    [Documentation]    Cria um produto no catĂˇlogo. Retorna o produtoId.
    ...                Sufixo timestamp+random na descriĂ§ĂŁo para evitar 409 entre runs.
    [Arguments]    ${descricao}=Filtro de Ă“leo E2E    ${valor}=85.00    ${quantidade}=100
    ${suffix}=    Evaluate    f"{int(__import__('time').time())}{__import__('random').randint(100,999)}"
    ${descricao}=    Set Variable    ${descricao} ${suffix}
    ${body}=    Create Dictionary
    ...    descricao=${descricao}
    ...    valor=${valor}
    ...    quantidade=${quantidade}
    ...    tipo=Peca
    ${response}=    POST    ${CADASTROS_URL}/produtos    json=${body}    expected_status=201
    ${id}=    Get From Dictionary    ${response.json()}    id
    Log    Produto criado: ${id} (descricao=${descricao})
    RETURN    ${id}

Criar Servico
    [Documentation]    Cria um serviĂ§o no catĂˇlogo. Retorna o servicoId.
    ...                Sufixo timestamp+random na descriĂ§ĂŁo para evitar 409 entre runs.
    [Arguments]    ${descricao}=Troca de Ă“leo E2E    ${valor}=120.00
    ${suffix}=    Evaluate    f"{int(__import__('time').time())}{__import__('random').randint(100,999)}"
    ${descricao}=    Set Variable    ${descricao} ${suffix}
    ${body}=    Create Dictionary
    ...    descricao=${descricao}
    ...    valor=${valor}
    ${response}=    POST    ${CADASTROS_URL}/servicos    json=${body}    expected_status=201
    ${id}=    Get From Dictionary    ${response.json()}    id
    Log    ServiĂ§o criado: ${id} (descricao=${descricao})
    RETURN    ${id}

Simular Aprovacao Webhook
    [Documentation]    Simula o cliente clicando no link de aprovaĂ§ĂŁo do orĂ§amento.
    ...    Calcula o token HMAC e chama o endpoint de webhook diretamente.
    [Arguments]    ${os_id}
    ${ts}=      Timestamp Unix Atual
    ${token}=   Calcular HMAC SHA256    ${os_id}    aprovar    ${ts}
    ${params}=    Create Dictionary    token=${token}    ts=${ts}
    ${response}=    GET
    ...    ${CADASTROS_URL}/webhooks/orcamentos/${os_id}/aprovar
    ...    params=${params}
    ...    expected_status=200
    Log    Webhook aprovaĂ§ĂŁo executado para OS ${os_id}

Simular Rejeicao Webhook
    [Documentation]    Simula o cliente clicando no link de rejeiĂ§ĂŁo do orĂ§amento.
    ...    Usa Create Dictionary para que requests cuide do URL-encoding do motivo
    ...    (espaĂ§os e acentos).
    [Arguments]    ${os_id}    ${motivo}=PreĂ§o elevado
    ${ts}=      Timestamp Unix Atual
    ${token}=   Calcular HMAC SHA256    ${os_id}    rejeitar    ${ts}
    ${params}=    Create Dictionary    token=${token}    ts=${ts}    motivo=${motivo}
    ${response}=    GET
    ...    ${CADASTROS_URL}/webhooks/orcamentos/${os_id}/rejeitar
    ...    params=${params}
    ...    expected_status=200
    Log    Webhook rejeiĂ§ĂŁo executado para OS ${os_id}
