# Tags das imagens Docker das 3 APIs. Use sha-<short> em CI para builds determinísticos.
# Padrão "latest" só para conveniência local — não usar em CI.
OS_IMAGE_TAG=latest
CADASTROS_IMAGE_TAG=latest
PAGAMENTOS_IMAGE_TAG=latest
