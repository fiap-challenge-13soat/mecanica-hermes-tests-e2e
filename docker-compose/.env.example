# Template de variáveis de ambiente para o stack E2E.
# Copie para .env (gitignored) e ajuste se necessário:
#   cp .env.example .env
#
# Os valores defaults aqui são SUFICIENTES para rodar a suíte E2E localmente.
# Não use estas credenciais em produção.

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=teste123A!
# OBSERVAÇÃO: POSTGRES_DB não é usado pelo container postgres do compose
# (a env var não é repassada ao container). O initdb cria os DBs reais
# (MecHermesOrdemDeServicoDB e MecHermesCadastrosDB) automaticamente.

# ─── Tags Docker das 3 APIs ─────────────────────────────────────────────────
# Default `latest` é OK para validação local. Em CI, fixe sha-<short> via
# org-level vars do GitHub para builds determinísticos.
OS_IMAGE_TAG=latest
CADASTROS_IMAGE_TAG=latest
PAGAMENTOS_IMAGE_TAG=latest

# ─── ASP.NET Core ───────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Testing

# ─── (Opcional) Licença MediatR ─────────────────────────────────────────────
# Necessária somente se a build do MediatR enforce licença em runtime.
# MEDIATR_LICENSE_KEY=
